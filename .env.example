# ============================================================
# Lewis Nautiques — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# --- Backend ---

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host:5432/lewis_nautiques?sslmode=require

# Port for the API server
PORT=5000

# Environment: development | production
NODE_ENV=development

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Admin panel access key — use a long random string in production
# Generate with: openssl rand -base64 48
ADMIN_SECRET=change_me_to_a_strong_secret_key

# Rate limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Frontend ---

# API base URL (defaults to /api via Vite proxy in development)
# Set to full URL in production: https://api.lewisnautiques.com/api
VITE_API_URL=/api
