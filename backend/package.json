{
  "name": "lewis-nautiques-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node -e \"require('dotenv').config(); const {execSync}=require('child_process'); execSync('psql '+process.env.DATABASE_URL+' -f src/db/schema.sql',{stdio:'inherit'})\"",
    "db:seed": "node -e \"require('dotenv').config(); const {execSync}=require('child_process'); execSync('psql '+process.env.DATABASE_URL+' -f src/db/seed.sql',{stdio:'inherit'})\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "winston": "^3.13.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
